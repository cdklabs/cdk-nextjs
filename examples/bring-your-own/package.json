{
  "name": "cdk-nextjs-example-bring-your-own",
  "type": "module",
  "private": true,
  "scripts": {
    "deploy:shared": "dotenv -- cdk deploy SharedInfra --require-approval never",
    "deploy:branch": "dotenv -- cdk deploy 'branch-*' --require-approval never",
    "destroy:branch": "dotenv -- cdk destroy 'branch-*' --force",
    "destroy:shared": "dotenv -- cdk destroy SharedInfra --force",
    "deploy:ci": "cdk deploy --all --require-approval never --outputs-file outputs.json",
    "destroy:ci": "cdk destroy --all --force"
  },
  "dependencies": {
    "aws-cdk-lib": "catalog:",
    "cdk-nextjs": "link:../..",
    "constructs": "catalog:",
    "tsx": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  }
}
